{
  "name": "actiontaint",
  "version": "0.1.0",
  "description": "actiontaint is an early-stage local-first developer tool.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "actiontaint": "./src/index.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "fixtures",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "node --check src/index.js",
    "test": "node --test",
    "smoke": "node src/index.js --help && node src/index.js --version && node src/cli.js --help && node src/index.js scan .github/workflows",
    "package:smoke": "npm run build && node scripts/pack-smoke.mjs",
    "release:check": "npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "github-actions",
    "audit",
    "security",
    "workflow",
    "permissions"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/actiontaint.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/actiontaint/issues"
  },
  "homepage": "https://github.com/rogerchappel/actiontaint#readme"
}
