{
  "name": "actiontaint",
  "version": "0.1.0",
  "description": "actiontaint is an early-stage local-first developer tool.",
  "type": "module",
  "main": "./src/index.js",
  "bin": {
    "actiontaint": "./src/index.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "files": [
    "src",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "CODE_OF_CONDUCT.md"
  ],
  "scripts": {
    "build": "node --check src/index.js",
    "test": "node --test",
    "smoke": "node src/index.js --help && node src/index.js --version",
    "package:smoke": "npm run build && npm pack --dry-run",
    "release:check": "npm test && npm run build && npm run smoke"
  },
  "keywords": [
    "github-actions",
    "audit",
    "security",
    "workflow",
    "permissions"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/actiontaint.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/actiontaint/issues"
  },
  "homepage": "https://github.com/rogerchappel/actiontaint#readme"
}
